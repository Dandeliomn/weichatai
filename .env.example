# =============================================================================
# 微信情感陪伴AI平台 v2.0 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值: cp .env.example .env
# =============================================================================

# ----- DeepSeek API 配置 (必填) -----
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ----- Redis 配置 -----
REDIS_URL=redis://redis:6379

# ----- PostgreSQL 配置 -----
DATABASE_URL=postgresql://weclaw:weclaw_secret@postgres:5432/weclaw_companion
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=weclaw_companion
POSTGRES_USER=weclaw
POSTGRES_PASSWORD=weclaw_secret

# ----- WeClaw 桥接层配置 -----
WECLAW_API_URL=http://weclaw-bridge:26322
WECLAW_BOT_ID=your-bot-id
WECLAW_API_TOKEN=your-api-token

# ----- JWT 认证配置 -----
# JWT 签名密钥 (生产环境请改为随机字符串: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret-string

# CORS 允许的来源 (默认允许所有)
CORS_ORIGIN=*

# ----- 文件上传配置 -----
# 上传文件目录 (Docker内路径，一般无需修改)
UPLOAD_DIR=/app/uploads

# ----- MinIO OSS 配置 (可选) -----
# 取消注释以下行以启用 MinIO 对象存储
# MINIO_ENDPOINT=minio
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin123
# MINIO_BUCKET=weclaw-uploads
# MINIO_USE_SSL=false

# ----- 主服务配置 -----
PORT=3000
NODE_ENV=production

# Worker 并发数
WORKER_CONCURRENCY=10

# ----- 可选配置 -----
LOG_LEVEL=info
CARE_CRON_SCHEDULE=0 8,13,20 * * *
SHORT_MEMORY_MAX_ROUNDS=10
SHORT_MEMORY_TTL=86400

# 设为 true 可在启动时立即执行一次关怀任务 (仅用于测试)
CARE_RUN_ON_START=false

# ----- SillyTavern 配置 (relay 直连 ST REST API，替代 ChatBridge WebSocket) -----
# ST 服务地址 (Docker 内)
ST_API_URL=http://sillytavern:8000
# ST 的 API Key (对应 st-config.yaml 中的 apiKey)
ST_API_KEY=your-sillytavern-api-key
# ST 中已配置好的角色名称
ST_CHARACTER=助手
# ST API 超时时间 (毫秒)
ST_TIMEOUT=60000

# ----- Hermes Gateway 配置 (relay 轮询来源) -----
# Hermes Gateway 的 SQLite 数据库路径
HERMES_DB_PATH=/root/.hermes/data/conversations.db
# 轮询间隔 (毫秒)
POLL_INTERVAL=2000
# 游标文件路径 (记录已处理的消息位置)
CURSOR_FILE=/tmp/hermes-relay-cursor.json

# ----- 人格注入 (Rich Protocol) -----
# active_persona.json 路径
PERSONA_PATH=/root/.hermes/active_persona.json
# 人格缓存时间 (毫秒)
PERSONA_CACHE_TTL=30000

# ----- 世界书 (World Book) -----
WORLDBOOK_DIR=/root/.hermes/worldbooks

# ----- iLink 回复 API -----
ILINK_API_URL=http://localhost:18789
ILINK_API_TOKEN=