# =============================================================================
# 微信情感陪伴AI平台 v2.0 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值: cp .env.example .env
# =============================================================================

# ----- DeepSeek API 配置 (必填) -----
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ----- Redis 配置 -----
REDIS_URL=redis://redis:6379

# ----- PostgreSQL 配置 -----
DATABASE_URL=postgresql://weclaw:your_password_here@postgres:5432/weclaw_companion
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=weclaw_companion
POSTGRES_USER=weclaw
POSTGRES_PASSWORD=your_password_here

# ----- JWT 认证配置 -----
JWT_SECRET=change-me-to-a-random-string-run-openssl-rand-hex-32
CORS_ORIGIN=*

# ----- 文件上传配置 -----
UPLOAD_DIR=/app/uploads

# ----- MinIO OSS 配置 -----
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-too
MINIO_BUCKET=weclaw-uploads
MINIO_USE_SSL=false

# ----- 主服务配置 -----
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
SHORT_MEMORY_MAX_ROUNDS=10
SHORT_MEMORY_TTL=86400
